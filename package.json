{
  "name": "lausd-plumbing-assistant",
  "private": true,
  "version": "0.1.0",
  "description": "LAUSD Standards/Decision Engine — facts in, LAUSD-compliant plumbing decisions out",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p packages/kb && tsc --noEmit -p packages/engine && tsc --noEmit -p apps/web",
    "lint": "eslint .",
    "dev": "npm --workspace apps/web run dev",
    "build": "npm --workspace apps/web run build",
    "preview": "npm --workspace apps/web run preview"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "eslint": "^9.17.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
